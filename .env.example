# Database 
DATABASE_URL=sqlite+aiosqlite:///./score.db
# DATABASE_URL=mysql+asyncmy://score:score_dev@localhost:3306/score

# Auth + Server
SECRET_KEY=example_secret
HOST=127.0.0.1
PORT=8000
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# LLM
HF_MODEL_ID=Qwen/Qwen3-8B
QUANTIZATION=8bit
LLM_MAX_NEW_TOKENS=640
LLM_TEMPERATURE=0.6
LLM_TOP_P=0.95
LLM_TIMEOUT_SECONDS=15

# transformers (HF + bitsandbytes) or llamacpp (GGUF).
# llamacpp needs GGUF_MODEL_PATH set to a local Q8_0 GGUF file.
LLM_BACKEND=transformers
GGUF_MODEL_PATH=
GGUF_QUANT=Q8_0
N_GPU_LAYERS=-1
N_CTX=4096

# Observability
LATENCY_LOG_PATH=./logs/latency.jsonl


